{
  "name": "it-support-call-logger",
  "version": "1.0.0",
  "description": "IT Support Call Logger - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "prebuild": "node scripts/build-icon.js",
    "build": "electron-builder",
    "build-win": "electron-builder --win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux"
  },
  "keywords": [
    "electron",
    "support",
    "call-logger",
    "it-support"
  ],
  "author": "",
  "license": "MIT",
  "engines": { "node": ">=18" },
  "dependencies": {
    "sql.js": "^1.14.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-icon-builder": "^2.0.1"
  },
  "build": {
    "appId": "com.itsupport.calllogger",
    "productName": "IT Support Call Logger",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "node_modules/**",
      "!dist/**/*",
      "!.git/**/*"
    ],
    "asarUnpack": [
      "**/node_modules/sql.js/**"
    ],
    "extraResources": [
      { "from": "build/icons/icon.ico", "to": "icon.ico" }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "Images/BigFish_Centered_Logo_Inverted.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "Images/BigFish_Centered_Logo_Inverted.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
