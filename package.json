{
  "name": "call-log",
  "version": "3.1.0",
  "description": "Call Log - Desktop Application",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:1": "electron . --user-data-dir=./.test-userdata/user1",
    "start:2": "electron . --user-data-dir=./.test-userdata/user2",
    "start:3": "electron . --user-data-dir=./.test-userdata/user3",
    "start:4": "electron . --user-data-dir=./.test-userdata/user4",
    "start:5": "electron . --user-data-dir=./.test-userdata/user5",
    "prebuild": "node scripts/validate-config.js && node scripts/build-icon.js",
    "build": "electron-builder",
    "build-win": "node scripts/clean-dist.js && electron-builder --win",
    "build-win:fresh": "npm run build-win",
    "build-mac": "electron-builder --mac",
    "build-linux": "electron-builder --linux",
    "clean": "node scripts/clean-dist.js"
  },
  "keywords": [
    "electron",
    "support",
    "call-logger",
    "it-support"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "gsap": "^3.14.2"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^24.9.1",
    "electron-icon-builder": "^2.0.1"
  },
  "build": {
    "appId": "com.calllog.app",
    "productName": "Call Log",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "node_modules/**",
      "!dist/**/*",
      "!.git/**/*",
      "supabaseConfig.js"
    ],
    "extraResources": [
      {
        "from": "build/icons/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "build/icons/icon.ico",
      "signAndEditExecutable": false
    },
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "icon": "Images/BigFish_Centered_Logo_Inverted.png",
      "category": "public.app-category.utilities"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "Images/BigFish_Centered_Logo_Inverted.png",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
