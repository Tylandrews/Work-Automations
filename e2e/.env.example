# Copy to .env in this folder (e2e/.env). That file is gitignored.
# Sign-in and Supabase cleanup need these; process environment overrides these values.

CALLLOG_TEST_EMAIL=
CALLLOG_TEST_PASSWORD=

# Required for run_supabase_e2e_cleanup (same values as CI secrets)
# SUPABASE_URL=
# SUPABASE_ANON_KEY=

# Optional: override when not using run_e2e_full.py auto-serve
# CALLLOG_TEST_BASE_URL=http://localhost:4173

# Browser for TC*.py: chromium (default), firefox, or webkit (install with playwright install)
# CALLLOG_TEST_BROWSER=chromium

# Optional: CI sets this to github.run_id-run_attempt; prefixes e2e cleanup markers for tracing
# CALLLOG_TEST_RUN_ID=

# Visible browser window: 0 / false / no / off
# CALLLOG_TEST_HEADLESS=1

# Parallel TC subprocesses. CI uses --workers 1. Locally, values above 1 can flake against one Supabase test user.
# py e2e/run_e2e_full.py -- --workers 4

# Optional: TC040 only — set to 1 when CALLLOG_TEST_EMAIL is an admin and account-admin Edge Function is deployed.
# CALLLOG_TEST_EXPECT_ADMIN=
